{
  "name": "aerial-estates",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev dist --port 8788",
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:preview": "npm run build && wrangler pages deploy dist --branch preview",
    "lint": "echo 'No linter configured yet'",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});console.log('dist/ cleaned')\""
  },
  "devDependencies": {
    "wrangler": "^3.40.0"
  }
}
